# ═══════════════════════════════════════
# LIS — Living Intelligent System
# Environment Configuration
# ═══════════════════════════════════════

# At least one LLM provider is required. Free options: Groq, Gemini, Cerebras
# LIS automatically falls back through providers in this order:
# Anthropic → Groq → Gemini → Cerebras → OpenRouter → Ollama

# --- LLM Providers ---
ANTHROPIC_API_KEY=your-anthropic-key-here
GROQ_API_KEY=your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here
CEREBRAS_API_KEY=your-cerebras-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
# Ollama: no key needed, just install and run locally

# --- Voice (optional) ---
# Fish Audio TTS (premium voice quality)
# FISH_API_KEY=your-fish-audio-key-here
# FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# --- Personalization ---
# Your name (LIS will address you by this)
USER_NAME=sir

# Server port
LIS_PORT=8340
